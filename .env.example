# Lemonade Control Center — Configuration

# Lemonade Server
LEMONADE_URL=http://localhost:13305
LEMONADE_ADMIN_API_KEY=

# Safety flags (disabled by default)
ENABLE_DELETE=false
ENABLE_RESTART=false
ENABLE_BENCH_LAB=false
TELEMETRY_SCOPE=host
CAPABILITIES_MODE=file

# LCC access control
# Localhost is trusted by default. LAN/remote API access requires LCC_API_KEY.
LCC_API_KEY=
REQUIRE_AUTH=false

# Unified runtime
# Development can still run FastAPI on 8000 and Vite on 5173.
# The single-process runtime uses APP_HOST/APP_PORT with `python -m app.run`.
APP_HOST=127.0.0.1
APP_PORT=17600
SERVE_FRONTEND=true
FRONTEND_BUILD_DIR=../frontend/build
LAN_MODE=false

# Container examples override APP_HOST/LAN_MODE/REQUIRE_AUTH and require LCC_API_KEY.
# LCC_PORT controls only the host-side Compose port mapping.
LCC_PORT=17600
